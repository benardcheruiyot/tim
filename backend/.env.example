# Backend configuration template
NODE_ENV=development
PORT=5000

# Comma-separated CORS origins are supported via FRONTEND_URLS
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=

# Database
MONGODB_URI=

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# M-Pesa Daraja configuration
MPESA_CONSUMER_KEY=replace_with_consumer_key
MPESA_CONSUMER_SECRET=replace_with_consumer_secret
MPESA_SHORTCODE=replace_with_shortcode
MPESA_PARTYB=replace_with_partyb
MPESA_PASSKEY=replace_with_passkey
MPESA_ENVIRONMENT=production
MPESA_TRANSACTION_TYPE=CustomerBuyGoodsOnline
MPESA_CALLBACK_URL=https://extracash.mkopaji.com/api/mpesa/callback

# Web Push VAPID
VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_SUBJECT=mailto:admin@extracash.mkopaji.com

# Optional app metadata for notifications
APP_NAME=Loan App
APP_PUBLIC_URL=https://extracash.mkopaji.com

# Loan settings
LOAN_MIN_AMOUNT=1000
LOAN_MAX_AMOUNT=100000
LOAN_INTEREST_RATE=0.1
LOAN_TERMS_DAYS=30,60,90
PROCESSING_FEE=300

# Email (optional)
EMAIL_SERVICE=gmail
EMAIL_FROM=noreply@extracash.mkopaji.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Logging / security
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
